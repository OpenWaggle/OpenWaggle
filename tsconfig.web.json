{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./out",
    "rootDir": ".",
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@openwaggle/waggle-core": ["./packages/waggle-core/src/index.ts"],
      "@openwaggle/waggle-core/*": ["./packages/waggle-core/src/*"]
    }
  },
  "include": [
    "src/renderer/src/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/renderer/src/test-setup.ts",
    "src/renderer/src/test-utils.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
