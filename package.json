{
  "name": "openwaggle",
  "version": "0.3.0-alpha.47",
  "description": "Desktop coding agent with multi-model waggle mode",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "prepare:native:node": "tsx scripts/rebuild-native-deps.ts node",
    "prepare:native:electron": "tsx scripts/rebuild-native-deps.ts electron",
    "dev": "pnpm docs:generate && pnpm prepare:native:electron && env -u ELECTRON_RUN_AS_NODE ELECTRON_ENABLE_LOGGING=1 electron-vite dev",
    "dev:debug": "pnpm docs:generate && pnpm prepare:native:electron && env -u ELECTRON_RUN_AS_NODE ELECTRON_ENABLE_LOGGING=1 electron-vite dev -- --remote-debugging-port=9222",
    "build": "pnpm docs:generate && pnpm prepare:native:electron && electron-vite build",
    "build:packages": "pnpm --filter @openwaggle/waggle-core build && pnpm --filter @openwaggle/pi-waggle build && pnpm --filter @openwaggle/extension-sdk build && pnpm --filter @openwaggle/extension-react build",
    "package:smoke": "tsx scripts/package-smoke.ts",
    "packaged-app:smoke": "tsx scripts/packaged-app-smoke.ts",
    "preview": "pnpm prepare:native:electron && electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && tsx scripts/build-mac.ts",
    "build:mac:all": "pnpm build && electron-builder --mac --arm64 --x64",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:website": "cd website && pnpm install && pnpm build",
    "extension:qa:install": "tsx scripts/install-extension-qa-fixture.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc -b tsconfig.web.json --emitDeclarationOnly",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "pnpm prepare:native:node && pnpm test:unit:raw && pnpm test:integration:raw && pnpm test:component",
    "test:all": "pnpm test && pnpm test:e2e:headless",
    "test:unit": "pnpm prepare:native:node && pnpm test:unit:raw",
    "test:unit:raw": "vitest run -c vitest.unit.config.ts",
    "test:component": "vitest run -c vitest.component.config.ts",
    "test:integration": "pnpm prepare:native:node && pnpm test:integration:raw",
    "test:integration:raw": "vitest run -c vitest.integration.config.ts",
    "test:coverage": "pnpm prepare:native:node && vitest run -c vitest.coverage.config.ts --coverage",
    "test:e2e": "pnpm test:e2e:headless",
    "test:e2e:headless": "pnpm build && playwright test",
    "test:e2e:headless:quick": "pnpm prepare:native:electron && playwright test",
    "test:e2e:headed": "pnpm build && playwright test --headed",
    "test:e2e:headed:quick": "pnpm prepare:native:electron && playwright test --headed",
    "lint": "biome check src/ packages/ fixtures/ && eslint src packages scripts website electron.vite.config.ts playwright.config.ts --max-warnings=0 && pnpm check:repository-standards",
    "lint:fix": "biome check --write src/ packages/ fixtures/ && eslint src packages scripts website electron.vite.config.ts playwright.config.ts --fix --max-warnings=0 && pnpm check:repository-standards",
    "format": "biome format --write src/ packages/ fixtures/",
    "check:repository-standards": "tsx scripts/check-repository-standards.ts",
    "api:snapshot:check": "pnpm build:packages && tsx scripts/package-api-snapshots.ts --check",
    "api:snapshot:update": "pnpm build:packages && tsx scripts/package-api-snapshots.ts --update",
    "api:snapshot:update:dry-run": "pnpm build:packages && tsx scripts/package-api-snapshots.ts --update --dry-run",
    "check:commits": "tsx scripts/check-conventional-commits.ts",
    "package-release:bootstrap": "tsx scripts/package-release-bootstrap.ts",
    "package-release:publish": "node scripts/package-release-publish.ts",
    "package-release:validate": "tsx scripts/package-release-validator.ts",
    "check:fast": "pnpm typecheck && pnpm lint",
    "check": "pnpm typecheck && pnpm lint && pnpm package-release:validate && pnpm api:snapshot:check && pnpm package:smoke",
    "prepush:main": "pnpm check && pnpm format && pnpm test:all",
    "website:capture-screenshots": "pnpm prepare:native:electron && tsx scripts/capture-website-screenshots.ts",
    "prepare": "husky",
    "website:dev": "pnpm --filter @openwaggle/website dev",
    "website:build": "pnpm --filter @openwaggle/website build",
    "website:preview": "pnpm --filter @openwaggle/website preview",
    "website:test": "pnpm --filter @openwaggle/website test",
    "docs:generate": "tsx scripts/generate-installed-docs.ts"
  },
  "packageManager": "pnpm@11.6.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenWaggle/OpenWaggle.git"
  },
  "dependencies": {
    "@diegogbrisa/ts-match": "1.6.1",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@lexical/react": "0.45.0",
    "@lobehub/icons-static-svg": "1.91.0",
    "@openwaggle/extension-sdk": "workspace:*",
    "@openwaggle/pi-waggle": "workspace:*",
    "@openwaggle/waggle-core": "workspace:*",
    "@tanstack/react-hotkeys": "0.10.0",
    "@tanstack/react-router": "1.170.11",
    "@xenova/transformers": "2.17.2",
    "better-sqlite3": "12.10.0",
    "electron-updater": "6.8.3",
    "hast-util-to-jsx-runtime": "2.3.6",
    "lexical": "0.45.0",
    "ms": "2.1.3",
    "node-pty": "1.1.0",
    "pi-mcp-adapter": "2.9.0",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "shiki": "4.2.0",
    "tesseract.js": "7.0.0",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@biomejs/biome": "2.4.16",
    "@effect/cluster": "0.59.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.107.0",
    "@effect/rpc": "0.75.1",
    "@effect/sql": "0.51.1",
    "@effect/sql-sqlite-node": "0.52.0",
    "@effect/workflow": "0.18.2",
    "@electron-toolkit/utils": "4.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/router-plugin": "1.168.14",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@total-typescript/shoehorn": "0.1.2",
    "@types/hast": "3.0.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "babel-plugin-react-compiler": "1.0.0",
    "diff": "9.0.0",
    "effect": "3.21.2",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "10.4.1",
    "eslint-import-resolver-node": "0.4.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "fast-glob": "3.3.3",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "jsdom": "29.1.1",
    "jszip": "3.10.1",
    "lucide-react": "1.17.0",
    "mammoth": "1.12.0",
    "playwright": "1.60.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-voice-visualizer": "2.1.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "unpdf": "1.6.2",
    "vite": "8.0.16",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.8",
    "yaml": "2.9.0",
    "zustand": "5.0.14"
  }
}
