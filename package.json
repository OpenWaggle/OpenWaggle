{
  "name": "openwaggle",
  "version": "0.3.0-alpha.38",
  "description": "Desktop coding agent with multi-model waggle mode",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "prepare:native:node": "tsx scripts/rebuild-native-deps.ts node",
    "prepare:native:electron": "tsx scripts/rebuild-native-deps.ts electron",
    "dev": "pnpm prepare:native:electron && env -u ELECTRON_RUN_AS_NODE ELECTRON_ENABLE_LOGGING=1 electron-vite dev",
    "dev:debug": "pnpm prepare:native:electron && env -u ELECTRON_RUN_AS_NODE ELECTRON_ENABLE_LOGGING=1 electron-vite dev -- --remote-debugging-port=9222",
    "build": "pnpm prepare:native:electron && electron-vite build",
    "preview": "pnpm prepare:native:electron && electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && tsx scripts/build-mac.ts",
    "build:mac:all": "pnpm build && electron-builder --mac --arm64 --x64",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:website": "cd website && pnpm install && pnpm build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc -b tsconfig.web.json --emitDeclarationOnly",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "pnpm prepare:native:node && pnpm test:unit:raw && pnpm test:integration:raw && pnpm test:component",
    "test:all": "pnpm test && pnpm test:e2e:headless",
    "test:unit": "pnpm prepare:native:node && pnpm test:unit:raw",
    "test:unit:raw": "vitest run -c vitest.unit.config.ts",
    "test:component": "vitest run -c vitest.component.config.ts",
    "test:integration": "pnpm prepare:native:node && pnpm test:integration:raw",
    "test:integration:raw": "vitest run -c vitest.integration.config.ts",
    "test:coverage": "pnpm prepare:native:node && vitest run -c vitest.coverage.config.ts --coverage",
    "test:e2e": "pnpm test:e2e:headless",
    "test:e2e:headless": "pnpm build && playwright test",
    "test:e2e:headless:quick": "pnpm prepare:native:electron && playwright test",
    "test:e2e:headed": "pnpm build && playwright test --headed",
    "test:e2e:headed:quick": "pnpm prepare:native:electron && playwright test --headed",
    "lint": "biome check src/ packages/ && eslint src packages scripts website electron.vite.config.ts playwright.config.ts --max-warnings=0 && pnpm check:repository-standards",
    "lint:fix": "biome check --write src/ packages/ && eslint src packages scripts website electron.vite.config.ts playwright.config.ts --fix --max-warnings=0 && pnpm check:repository-standards",
    "format": "biome format --write src/ packages/",
    "check:repository-standards": "tsx scripts/check-repository-standards.ts",
    "check:fast": "pnpm typecheck && pnpm lint",
    "check": "pnpm typecheck && pnpm lint",
    "prepush:main": "pnpm check && pnpm format && pnpm test:all",
    "website:capture-screenshots": "pnpm prepare:native:electron && tsx scripts/capture-website-screenshots.ts",
    "prepare": "husky",
    "website:dev": "pnpm --filter @openwaggle/website dev",
    "website:build": "pnpm --filter @openwaggle/website build",
    "website:preview": "pnpm --filter @openwaggle/website preview",
    "website:test": "pnpm --filter @openwaggle/website test"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty",
      "sharp"
    ],
    "overrides": {
      "electron-vite>vite": "$vite",
      "@tanstack/history": "1.161.6",
      "@tanstack/query-core": "5.100.10",
      "@tanstack/react-hotkeys": "0.10.0",
      "@tanstack/react-query": "5.100.10",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/router-core": "1.169.2",
      "@tanstack/router-generator": "1.166.42",
      "@tanstack/router-plugin": "1.167.35",
      "@tanstack/router-utils": "1.161.8",
      "@tanstack/virtual-file-routes": "1.161.7"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenWaggle/OpenWaggle.git"
  },
  "dependencies": {
    "@diegogbrisa/ts-match": "1.2.0",
    "@lexical/react": "^0.42.0",
    "@lobehub/icons-static-svg": "^1.87.0",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "@openwaggle/pi-waggle": "workspace:*",
    "@openwaggle/waggle-core": "workspace:*",
    "@tanstack/react-hotkeys": "0.10.0",
    "@tanstack/react-router": "1.169.2",
    "@xenova/transformers": "2.17.2",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.6.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lexical": "^0.42.0",
    "ms": "2.1.3",
    "node-pty": "^1.1.0",
    "pi-mcp-adapter": "2.5.4",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tesseract.js": "^6.0.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/sql": "^0.49.0",
    "@effect/sql-sqlite-node": "^0.50.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-query": "5.100.11",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/router-plugin": "1.167.35",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/shoehorn": "0.1.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "diff": "^8.0.3",
    "effect": "^3.19.19",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-import": "2.32.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jiti": "2.7.0",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.572.0",
    "mammoth": "1.11.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-voice-visualizer": "2.0.8",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.59.4",
    "unpdf": "1.4.0",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0",
    "zustand": "^5.0.11"
  }
}
