{
  "name": "openwaggle",
  "version": "0.3.0-alpha.14",
  "description": "Desktop coding agent with multi-model waggle mode",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "prepare:native:node": "tsx scripts/rebuild-native-deps.ts node",
    "prepare:native:electron": "tsx scripts/rebuild-native-deps.ts electron",
    "dev": "pnpm prepare:native:electron && ELECTRON_ENABLE_LOGGING=1 electron-vite dev",
    "dev:debug": "pnpm prepare:native:electron && ELECTRON_ENABLE_LOGGING=1 electron-vite dev -- --remote-debugging-port=9222",
    "build": "pnpm prepare:native:electron && electron-vite build",
    "preview": "pnpm prepare:native:electron && electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "build:website": "cd website && pnpm install && pnpm build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc -b tsconfig.web.json --emitDeclarationOnly",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "pnpm prepare:native:node && pnpm test:unit:raw && pnpm test:integration:raw && pnpm test:component",
    "test:all": "pnpm test && pnpm test:e2e:headless",
    "test:unit": "pnpm prepare:native:node && pnpm test:unit:raw",
    "test:unit:raw": "vitest run -c vitest.unit.config.ts",
    "test:tanstack-known-issues": "pnpm prepare:native:node && pnpm test:unit:raw -- src/main/agent/tanstack-known-issues.unit.test.ts src/main/agent/continuation-normalizer.unit.test.ts src/main/agent/stream-part-collector.unit.test.ts src/renderer/src/components/chat/useVirtualRows.unit.test.ts",
    "test:component": "vitest run -c vitest.component.config.ts",
    "test:integration": "pnpm prepare:native:node && pnpm test:integration:raw",
    "test:integration:raw": "vitest run -c vitest.integration.config.ts",
    "test:coverage": "pnpm prepare:native:node && vitest run --coverage",
    "test:e2e": "pnpm test:e2e:headless",
    "test:e2e:headless": "pnpm build && playwright test",
    "test:e2e:headless:quick": "pnpm prepare:native:electron && playwright test",
    "test:e2e:headed": "pnpm build && playwright test --headed",
    "test:e2e:headed:quick": "pnpm prepare:native:electron && playwright test --headed",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "check:fast": "pnpm typecheck && pnpm lint",
    "check:pattern-style": "tsx scripts/check-pattern-style.ts",
    "check:decision-size": "tsx scripts/check-decision-size.ts",
    "check:magic-numbers": "tsx scripts/check-magic-numbers.ts",
    "check:architecture": "tsx scripts/check-architecture.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm check:pattern-style && pnpm check:decision-size && pnpm check:magic-numbers && pnpm check:architecture",
    "prepush:main": "pnpm check && pnpm format && pnpm test:all",
    "website:capture-screenshots": "pnpm prepare:native:electron && tsx scripts/capture-website-screenshots.ts",
    "prepare": "husky",
    "website:dev": "pnpm --filter @openwaggle/website dev",
    "website:build": "pnpm --filter @openwaggle/website build",
    "website:preview": "pnpm --filter @openwaggle/website preview"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "node-pty",
      "sharp"
    ],
    "overrides": {
      "electron-vite>vite": "$vite"
    },
    "patchedDependencies": {
      "@tanstack/ai@0.8.1": "patches/@tanstack__ai@0.8.1.patch"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenWaggle/OpenWaggle.git"
  },
  "dependencies": {
    "@lexical/history": "^0.42.0",
    "@lexical/plain-text": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@xenova/transformers": "2.17.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.6.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lexical": "^0.42.0",
    "node-pty": "^1.1.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tesseract.js": "^6.0.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/sql": "^0.49.0",
    "@effect/sql-sqlite-node": "^0.50.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "~1.27.1",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/ai": "0.8.1",
    "@tanstack/ai-anthropic": "0.7.0",
    "@tanstack/ai-gemini": "0.8.2",
    "@tanstack/ai-grok": "0.6.2",
    "@tanstack/ai-ollama": "0.6.2",
    "@tanstack/ai-openai": "0.7.1",
    "@tanstack/ai-openrouter": "0.6.6",
    "@tanstack/ai-react": "0.7.2",
    "@tanstack/devtools-event-bus": "^0.4.1",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-ai-devtools": "^0.2.8",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "diff": "^8.0.3",
    "effect": "^3.19.19",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.572.0",
    "mammoth": "1.11.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "react-voice-visualizer": "2.0.8",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.6.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unpdf": "1.4.0",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0",
    "zustand": "^5.0.11"
  }
}
