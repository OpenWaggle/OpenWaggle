{
  "name": "openwaggle",
  "version": "0.1.0",
  "description": "Desktop coding agent with multi-model waggle mode",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:win": "pnpm build && electron-builder --win",
    "build:linux": "pnpm build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:component",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:component": "vitest run -c vitest.component.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "check:pattern-style": "node scripts/check-pattern-style.mjs",
    "check:decision-size": "node scripts/check-decision-size.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm check:pattern-style && pnpm check:decision-size"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty",
      "sharp"
    ]
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "~1.27.1",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/ai": "0.5.0",
    "@tanstack/ai-anthropic": "0.5.0",
    "@tanstack/ai-gemini": "0.5.0",
    "@tanstack/ai-grok": "0.5.0",
    "@tanstack/ai-ollama": "0.5.0",
    "@tanstack/ai-openai": "0.5.0",
    "@tanstack/ai-openrouter": "0.5.0",
    "@tanstack/ai-react": "0.5.3",
    "@xenova/transformers": "2.17.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff": "^8.0.3",
    "electron-store": "^11.0.2",
    "fast-glob": "^3.3.3",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.572.0",
    "mammoth": "1.11.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.6.0",
    "tesseract.js": "^6.0.1",
    "unpdf": "1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "@biomejs/biome": "^2.4.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-event-bus": "^0.4.1",
    "@tanstack/devtools-vite": "^0.5.1",
    "@tanstack/react-ai-devtools": "^0.2.8",
    "@tanstack/react-devtools": "^0.9.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "^4.0.18"
  }
}
