{
  "mcpServers": {
    "electron-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://127.0.0.1:9222"
      ]
    },
    "electron-test": {
      "command": "npx",
      "args": [
        "-y",
        "electron-test-mcp@latest"
      ]
    }
  }
}
