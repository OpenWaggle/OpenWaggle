{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@openwaggle/pi-waggle": ["./packages/pi-waggle/src/index.ts"],
      "@openwaggle/pi-waggle/*": ["./packages/pi-waggle/src/*"],
      "@openwaggle/waggle-core": ["./packages/waggle-core/src/index.ts"],
      "@openwaggle/waggle-core/*": ["./packages/waggle-core/src/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.web.json" },
    { "path": "./tsconfig.renderer-tests.json" }
  ]
}
