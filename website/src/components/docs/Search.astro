---
---

<div id="pagefind-search" class="relative">
  <!-- Fallback search input shown when Pagefind is unavailable (dev mode) -->
  <div id="pagefind-fallback" class="flex items-center gap-2 rounded-lg border border-border-light bg-bg-secondary px-3 py-2">
    <svg class="h-4 w-4 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
    </svg>
    <span class="text-sm text-text-tertiary">Search docs...</span>
    <kbd class="ml-auto hidden rounded border border-border px-1.5 py-0.5 text-[10px] text-text-tertiary sm:inline-block">⌘K</kbd>
  </div>
  <!-- Pagefind UI mounts here, hidden until confirmed working -->
  <div id="pagefind-container" class="hidden"></div>
</div>

<script>
  async function initSearch() {
    const fallback = document.getElementById('pagefind-fallback');
    const pagefindContainer = document.getElementById('pagefind-container');
    if (!pagefindContainer) return;

    try {
      // Check if pagefind index exists (only available after build)
      const res = await fetch('/pagefind/pagefind.js', { method: 'HEAD' });
      if (!res.ok) return; // Index not built — keep fallback

      const { PagefindUI } = await import('@pagefind/default-ui');
      fallback?.remove();
      pagefindContainer.classList.remove('hidden');
      new PagefindUI({
        element: '#pagefind-container',
        showSubResults: true,
        showImages: false,
      });
    } catch {
      // Pagefind not available (dev mode) — keep fallback visible
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }

  // Cmd+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const input = document.querySelector<HTMLInputElement>('#pagefind-container input')
        ?? document.querySelector<HTMLInputElement>('#pagefind-search input');
      input?.focus();
    }
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: #f5a623;
    --pagefind-ui-text: #e7e9ee;
    --pagefind-ui-background: #1a1d22;
    --pagefind-ui-border: #2a3240;
    --pagefind-ui-tag: #1f232a;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: Inter, sans-serif;
  }
</style>
