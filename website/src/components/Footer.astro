---
---

<footer class="w-full border-t border-border">
  <div class="mx-auto max-w-[1440px] px-6 md:px-20">
    <!-- Main footer -->
    <div class="flex flex-col gap-12 py-12 md:flex-row md:justify-between">
      <!-- Left: logo + tagline -->
      <div class="flex flex-col gap-3 md:max-w-[300px]">
        <a href="/" class="flex items-center">
          <img src="/logo-lockup.svg" alt="OpenWaggle" class="h-8" />
        </a>
        <p class="text-[13px] leading-[1.5] text-text-tertiary">
          The coding harness that lets your agents waggle.
        </p>
      </div>

      <!-- Right: nav columns -->
      <div class="flex gap-16 md:gap-20">
        <div class="flex flex-col gap-3">
          <span class="text-xs font-semibold text-text-tertiary">Product</span>
          <a href="/docs/getting-started/installation" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Install</a>
          <a href="https://github.com/OpenWaggle/OpenWaggle/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Changelog</a>
          <a href="https://github.com/OpenWaggle/OpenWaggle/projects" target="_blank" rel="noopener noreferrer" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Roadmap</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="text-xs font-semibold text-text-tertiary">Docs</span>
          <a href="/docs/getting-started/installation" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Getting Started</a>
          <a href="/docs/using-openwaggle/waggle-mode" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Waggle Mode</a>
          <a href="/docs/providers/overview" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Providers</a>
          <a href="/docs/configuration/app-settings" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Configuration</a>
        </div>
        <div class="flex flex-col gap-3">
          <span class="text-xs font-semibold text-text-tertiary">Community</span>
          <a href="https://github.com/OpenWaggle/OpenWaggle" target="_blank" rel="noopener noreferrer" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">GitHub</a>
          <a href="https://github.com/OpenWaggle/OpenWaggle/discussions" target="_blank" rel="noopener noreferrer" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">Discussions</a>
          <a href="https://github.com/OpenWaggle/OpenWaggle/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-[13px] text-text-tertiary transition-colors hover:text-text-secondary">License</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 border-t border-border py-6 md:flex-row">
      <span class="text-xs text-text-tertiary">&copy; 2026 OpenWaggle. All rights reserved.</span>
      <div class="flex items-center gap-6">
        <a href="https://github.com/OpenWaggle/OpenWaggle" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg border border-border-light px-4 py-2 text-sm font-medium text-text-secondary transition-colors hover:border-border hover:text-text-primary">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
          Star on GitHub
        </a>
        <a href="https://buymeacoffee.com/dgarciabria" target="_blank" rel="noopener noreferrer" class="transition-opacity hover:opacity-80">
          <img src="/bmc-button.png" alt="Buy me a coffee" class="h-10 rounded-lg" />
        </a>
      </div>
    </div>
  </div>
</footer>
