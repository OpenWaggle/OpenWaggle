---
import SectionHeader from '@/components/SectionHeader.astro';
import HoneycombBackground from '@/components/HoneycombBackground.astro';

interface Step {
  num: string;
  color: string;
  bgColor: string;
  title: string;
  desc: string;
}

const steps: Step[] = [
  {
    num: '1',
    color: 'var(--color-accent)',
    bgColor: 'color-mix(in srgb, var(--color-accent) 10%, transparent)',
    title: 'Configure your team',
    desc: 'Pick two models from different providers. Assign roles, strengths, and collaboration rules. Save as a reusable preset.',
  },
  {
    num: '2',
    color: 'var(--color-info)',
    bgColor: 'color-mix(in srgb, var(--color-info) 10%, transparent)',
    title: 'Agents collaborate',
    desc: "They take structured turns — reading files, running commands, challenging each other's assumptions. You watch in real time.",
  },
  {
    num: '3',
    color: 'var(--color-success)',
    bgColor: 'color-mix(in srgb, var(--color-success) 10%, transparent)',
    title: 'Consensus reached',
    desc: 'When agents converge on a solution, a synthesis step combines their findings into a clear recommendation with agreed points and open questions.',
  },
];
---

<section class="relative w-full overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 100% 100% at 50% 20%, rgba(245, 166, 35, 0.03) 0%, transparent 70%)"></div>
  </div>
  <HoneycombBackground fadeBottom />
  <div class="relative z-10 mx-auto max-w-[1440px] px-6 py-20 md:px-20">
    <div class="flex flex-col items-center gap-12">
      <SectionHeader
        label="HOW WAGGLE MODE WORKS"
        title="Two models collaborate like bees in a hive"
        description="Just as forager bees perform a waggle dance to share what they've found, OpenWaggle orchestrates two AI agents in structured turns until they converge."
      />

      <div class="grid w-full grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
        {steps.map((step) => (
          <div class="flex flex-col gap-5 rounded-xl bg-bg-secondary p-8 border border-border">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-lg"
              style={`background: ${step.bgColor}`}
            >
              <span
                class="font-mono text-base font-bold"
                style={`color: ${step.color}`}
              >
                {step.num}
              </span>
            </div>
            <h3 class="font-display text-xl font-semibold text-text-primary">{step.title}</h3>
            <p class="text-sm leading-[1.6] text-text-tertiary">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
