---
import HoneycombBackground from '@/components/HoneycombBackground.astro';
---

<section class="relative w-full overflow-hidden">
  <HoneycombBackground />
  <div class="relative z-10 mx-auto flex max-w-[1440px] flex-col items-center gap-5 px-6 py-12 md:px-20">
    <a
      href="https://pi.dev"
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-3 rounded-full border border-border-light bg-bg-secondary/80 px-4 py-2 transition-colors hover:border-accent/60"
      aria-label="Powered by Pi"
    >
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-bg-tertiary ring-1 ring-border-light">
        <img src="/pi-logo.svg" alt="Pi" class="h-4 w-4" loading="lazy" />
      </span>
      <span class="text-[13px] font-semibold text-text-secondary transition-colors group-hover:text-text-primary">
        Powered by Pi
      </span>
    </a>

    <div class="flex max-w-[720px] flex-col items-center gap-2 text-center">
      <p class="font-display text-2xl font-semibold leading-tight text-text-primary md:text-[32px]">
        A focused desktop workspace for Pi's agent runtime and OpenWaggle's collaborative workflows.
      </p>
      <p class="max-w-[620px] text-sm leading-[1.7] text-text-tertiary md:text-base">
        OpenWaggle stays aligned with Pi's runtime model while adding a polished local interface.
      </p>
    </div>
  </div>
</section>
