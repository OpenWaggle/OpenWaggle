---
import SectionHeader from '@/components/SectionHeader.astro';
import { Shield, Mic, Network, Paperclip, Terminal, FolderTree, Gauge } from 'lucide-astro';

interface FeatureCard {
  Icon: typeof Shield;
  color: string;
  title: string;
  desc: string;
}

const cards: FeatureCard[] = [
  { Icon: Shield, color: 'var(--color-accent)', title: 'Local-first privacy', desc: 'Sessions, settings, and voice data stay on your machine. Provider credentials are resolved through Pi auth storage, environment, or project configuration.' },
  { Icon: Mic, color: 'var(--color-info)', title: 'Voice input', desc: 'Local Whisper transcription. Speak your instructions — no audio leaves your machine.' },
  { Icon: Network, color: 'var(--color-success)', title: 'Pi provider catalog', desc: 'Provider and model lists come from Pi, including provider-qualified model ids so the same model can be selected through different hosts.' },
  { Icon: Paperclip, color: 'var(--color-agent-violet)', title: 'Rich attachments', desc: 'Drop text files, PDFs, and images into the session. Content is extracted automatically with OCR for images.' },
  { Icon: Terminal, color: 'var(--color-agent-emerald)', title: 'Built-in terminal', desc: 'Full PTY terminal emulation with xterm.js. Toggle with a shortcut — run commands without leaving the app.' },
  { Icon: FolderTree, color: 'var(--color-accent)', title: 'Project sessions', desc: 'The sidebar groups Pi-backed sessions by project, matching the project-first model used by coding agents.' },
  { Icon: Gauge, color: 'var(--color-info)', title: 'Context transparency', desc: 'See Pi-reported context usage in the composer and use /compact with optional instructions when you want manual compaction.' },
];
---

<section class="w-full">
  <div class="mx-auto max-w-[1440px] px-6 py-20 md:px-20">
    <div class="flex flex-col items-center gap-12">
      <SectionHeader
        label="BUILT FOR DEVELOPERS"
        title="Every detail considered"
      />

      <div class="grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {cards.map(({ Icon, color, title, desc }) => (
          <div class="flex flex-col gap-4 rounded-xl bg-bg-secondary p-7 border border-border">
            <div aria-hidden="true">
              <Icon size={24} color={color} />
            </div>
            <h3 class="font-display text-lg font-semibold text-text-primary">{title}</h3>
            <p class="text-sm leading-[1.6] text-text-tertiary">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
