{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noCheck": true,
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@openwaggle/extension-sdk": ["./packages/extension-sdk/src/index.ts"],
      "@openwaggle/extension-sdk/*": ["./packages/extension-sdk/src/*"],
      "@openwaggle/extension-react": ["./packages/extension-react/src/index.tsx"]
    },
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/renderer/src/**/*.test.ts",
    "src/renderer/src/**/*.test.tsx",
    "src/renderer/src/test-setup.ts",
    "src/renderer/src/test-utils.tsx",
    "src/renderer/src/test-utils/**/*.ts",
    "src/renderer/src/test-utils/**/*.tsx"
  ],
  "exclude": []
}
