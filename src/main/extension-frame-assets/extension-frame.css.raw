:root {
  color-scheme: dark;
  font-family: ui-sans-serif, system-ui, sans-serif;
  background: transparent;
  color: #e6edf3;
}

* {
  box-sizing: border-box;
}

html,
body,
#openwaggle-extension-root {
  height: 100%;
  min-height: 0;
}

body {
  margin: 0;
  background: transparent;
}

#openwaggle-extension-root {
  min-width: 0;
}

[role='alert'] {
  padding: 12px;
  color: #ff6b6b;
  font: 12px ui-sans-serif, system-ui, sans-serif;
}
